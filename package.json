{
  "name": "aws-practitioner-backend",
  "version": "0.1.0",
  "bin": {
    "aws-practitioner-backend": "bin/aws-practitioner-backend.js"
  },
  "scripts": {
    "build": "./node_modules/.bin/tsc",
    "watch": "./node_modules/.bin/tsc -w",
    "test": "jest",
    "cdk": "./node_modules/.bin/cdk",
    "cdk:deploy": "npm run build && ./node_modules/.bin/cdk deploy --require-approval never --all",
    "fillTables": "ts-node scripts/fillTables.ts"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30",
    "@types/node": "^24.12.2",
    "aws-cdk": "2.1117.0",
    "jest": "^30",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "aws-cdk-lib": "^2.247.0",
    "constructs": "^10.5.0"
  }
}
